<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Electron / Chromium under Hardened Runtime (ad-hoc or Developer ID). -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
	<!-- Network for model APIs, updates, MCP, etc. -->
	<key>com.apple.security.network.client</key>
	<true/>
	<key>com.apple.security.network.server</key>
	<true/>
	<!-- Voice Mode microphone prompt (also NSMicrophoneUsageDescription in extendInfo). -->
	<key>com.apple.security.device.audio-input</key>
	<true/>
	<!-- System Settings → Privacy → Automation (Apple Events to Calendar / Reminders / Notes). -->
	<key>com.apple.security.automation.apple-events</key>
	<true/>
</dict>
</plist>
