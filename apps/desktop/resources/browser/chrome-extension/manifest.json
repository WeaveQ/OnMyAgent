{
  "manifest_version": 3,
  "name": "OnMyAgent Browser",
  "version": "0.1.0",
  "description": "Connect explicitly claimed Chrome tabs to OnMyAgent browser sessions.",
  "permissions": [
    "debugger",
    "downloads",
    "history",
    "nativeMessaging",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "service-worker.mjs",
    "type": "module"
  },
  "action": {
    "default_title": "OnMyAgent Browser"
  }
}
