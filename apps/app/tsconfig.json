{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": [
      "ES2023",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "moduleResolution": "Bundler",
    // baseUrl is deprecated (removed in TS 7). paths resolve relative to this file.
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "vite/client",
      "node"
    ]
  },
  "include": [
    "src/index.react.tsx",
    "src/types/**/*.d.ts",
    "src/components/**/*",
    "src/i18n/**/*",
    "src/lib/**/*",
    "src/react-app/**/*",
    "src/app/lib/**/*",
    "src/app/cloud/**/*",
    "src/app/data/**/*",
    "src/app/utils/**/*",
    "src/app/constants.ts",
    "src/app/types.ts",
    "src/app/theme.ts",
    "src/app/mcp.ts",
    "vite.config.ts"
  ],
  "exclude": [
    "src/react-app/domains/session/expert-marketplace/builtin-experts/plugins/**",
    "src/react-app/domains/session/skills-marketplace/builtin-skills/**"
  ]
}
