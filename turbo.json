{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["ONMYAGENT_DEV_MODE"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:local": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "check:electron": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:runtime": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:release-smoke": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:ui": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:version-gate": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
